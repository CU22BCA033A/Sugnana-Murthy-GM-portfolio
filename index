// ── MATRIX RAIN ──
const canvas=document.getElementById('matrix-bg'),ctx=canvas.getContext('2d');
function resize(){canvas.width=window.innerWidth;canvas.height=window.innerHeight;}
resize();window.addEventListener('resize',resize);
const chars='ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&*|;:/\\アイウエオカキクケコ';
const fs=12;let drops=[];
function initDrops(){drops=Array(Math.floor(canvas.width/fs)).fill(1);}
initDrops();window.addEventListener('resize',initDrops);
setInterval(()=>{
  ctx.fillStyle='rgba(2,12,20,0.05)';ctx.fillRect(0,0,canvas.width,canvas.height);
  drops.forEach((y,i)=>{
    ctx.fillStyle=Math.random()>0.5?'#00d4ff':'#00ff88';
    ctx.font=fs+'px monospace';
    ctx.fillText(chars[Math.floor(Math.random()*chars.length)],i*fs,y*fs);
    if(y*fs>canvas.height&&Math.random()>0.975)drops[i]=0;
    drops[i]++;
  });
},50);

// ── SCROLL PROGRESS ──
window.addEventListener('scroll',()=>{
